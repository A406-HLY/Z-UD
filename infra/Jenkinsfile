pipeline {
    agent any

    options {
        timestamps()
        disableConcurrentBuilds()
    }

    environment {
        PROJECT_PATH = "/home/ubuntu/app/S14P21A406"
        CD_JOB_NAME = "CD/develop"
    }

    stages {
        stage('1. Checkout & Hard Reset') {
            steps {
                dir("${env.PROJECT_PATH}") {
                    script {
                        withCredentials([usernamePassword(credentialsId: 'Gitlab_PAT_Username_with_Password',
                                                         passwordVariable: 'GIT_PASSWORD',
                                                         usernameVariable: 'GIT_USERNAME')]) {
                            sh """
                                # 1. Git이 인증 정보를 환경변수에서 가져오도록 임시 설정
                                git config credential.helper '!f() { echo username=\$GIT_USERNAME; echo password=\$GIT_PASSWORD; }; f'

                                # 2. 이미 등록된 origin을 사용하여 fetch (주소 복잡하게 적을 필요 없음)
                                git fetch origin develop

                                # 3. 브랜치 전환 및 리셋
                                git checkout develop
                                git reset --hard origin/develop

                                # 4. 설정 해제 (보안을 위해)
                                git config --unset credential.helper
                            """
                        }
                    }
                }
            }
        }

        stage('2. Build Backend Image (Local)') {
            steps {
                dir("${env.PROJECT_PATH}/backend") {
                    script {
                        echo "🛠️ Building 'backend:latest' image..."
                        sh "docker build --no-cache -t backend:latest ."
                    }
                }
            }
        }

        stage('3. Trigger CD/develop') {
            steps {
                script {
                    echo "📦 Triggering Downstream CD Job: ${env.CD_JOB_NAME}"
                    build job: env.CD_JOB_NAME,
                          wait: true,
                          propagate: true
                }
            }
        }
    }

    post {
        success {
            echo "✅ CI/Infra Pipeline Success! backend:latest is ready."
        }
        failure {
            echo "❌ Pipeline Failed. Please check the logs."
        }
    }
}